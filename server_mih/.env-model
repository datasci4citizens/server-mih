# URLs da aplicação (talvez adicione http://10.0.2.2 ou http://localhost para desenvolvimento android)
FRONT_URL=http://localhost:5173
SERVER_URL=http://localhost:8000

ALLOWED_HOSTS="localhost,127.0.0.1,0.0.0.0,[::1]"

# Variaveis MINIO
MINIO_IMAGES_BUCKET=mih
MINIO_DOCUMENTS_BUCKET=documents
MINIO_DOMAIN=localhost:9000 # ou seu dominio de produção/ngrok (sem http://)
MINIO_SECURE=false # true se estiver usando https
MINIO_ACCESS_KEY=miniodev
MINIO_SECRET_KEY=miniodev

# Banco de Dados (PostgreSQL)
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Autenticação Google (Django)
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=